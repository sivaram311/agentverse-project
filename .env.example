# Runtime URLs are set by start.ps1 (-EnvName preprod|prod|dev).
# Do not point these at DEV (:8080 / :9000) on F: or G:.
# NEXT_PUBLIC_* must match the target env at *build* time for client JWT iss checks.
# Live F/G (0.3.8+): css-next IdP — CSS_AUTH_URL=http://127.0.0.1:5910
#   NEXT_PUBLIC_CSS_ISSUER=https://css-next.delena.buzz · CSS_CLIENT_ID=agent-portal

# AGENT_PORTAL_API_URL=
# CSS_AUTH_URL=
# NEXT_PUBLIC_CSS_ISSUER=
# CSS_CLIENT_ID=agent-portal
# NEXT_PUBLIC_DEFAULT_WORKSPACE=demo
# NEXT_PUBLIC_APP_VERSION=

# Optional comma-separated workspace path *prefixes* for Session Desk (client gate).
# Empty = unrestricted (Portal still enforces AGENT_WORKSPACE_ROOT / ALLOWED_ROOTS).
# Prefer absolute roots aligned with Portal AGENT_WORKSPACE_ALLOWED_ROOTS:
# NEXT_PUBLIC_WORKSPACE_ALLOWLIST=E:/MyWorkspace,E:/Source,E:/wt,F:/apps,G:/apps
