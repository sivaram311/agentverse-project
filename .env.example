# Runtime URLs are set by start.ps1 (-EnvName preprod|prod|dev).
# Do not point these at DEV (:8080 / :9000) on F: or G:.
# NEXT_PUBLIC_* must match the target env at *build* time for client JWT iss checks.

# AGENT_PORTAL_API_URL=
# CSS_AUTH_URL=
# NEXT_PUBLIC_CSS_ISSUER=
# NEXT_PUBLIC_DEFAULT_WORKSPACE=demo
# NEXT_PUBLIC_APP_VERSION=

# Optional comma-separated workspace paths for Session Desk / picker quick-picks.
# Empty = unrestricted (portal still enforces AGENT_WORKSPACE_ROOT).
# NEXT_PUBLIC_WORKSPACE_ALLOWLIST=demo,G:\apps\agent-portal\workspaces\platform-tasks
